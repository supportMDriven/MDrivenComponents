  <SpanVariables>
    <SpanVariable
      Name="vMockData"
      InitialValue="{&#xD;&#xA;  &quot;declarationOfConformity&quot;: {&#xD;&#xA;    &quot;documentTitle&quot;: &quot;EU Declaration of Conformity&quot;,&#xD;&#xA;    &quot;documentNumber&quot;: &quot;DoC-2026-06-24-001&quot;,&#xD;&#xA;    &quot;issueDate&quot;: &quot;2026-06-24&quot;,&#xD;&#xA;    &quot;revision&quot;: &quot;1.0&quot;,&#xD;&#xA;    &quot;manufacturer&quot;: {&#xD;&#xA;      &quot;legalName&quot;: &quot;ElectroTech GmbH&quot;,&#xD;&#xA;      &quot;tradingName&quot;: &quot;ElectroTech&quot;,&#xD;&#xA;      &quot;registrationNumber&quot;: &quot;HRB 123456&quot;,&#xD;&#xA;      &quot;vatNumber&quot;: &quot;DE123456789&quot;,&#xD;&#xA;      &quot;address&quot;: {&#xD;&#xA;        &quot;street&quot;: &quot;Industriestrasse 42&quot;,&#xD;&#xA;        &quot;city&quot;: &quot;Berlin&quot;,&#xD;&#xA;        &quot;postalCode&quot;: &quot;10115&quot;,&#xD;&#xA;        &quot;country&quot;: &quot;Germany&quot;,&#xD;&#xA;        &quot;state&quot;: &quot;Berlin&quot;&#xD;&#xA;      },&#xD;&#xA;      &quot;contact&quot;: {&#xD;&#xA;        &quot;person&quot;: &quot;Dr. Anna Schmidt&quot;,&#xD;&#xA;        &quot;position&quot;: &quot;Quality Assurance Manager&quot;,&#xD;&#xA;        &quot;phone&quot;: &quot;+49 30 12345678&quot;,&#xD;&#xA;        &quot;email&quot;: &quot;compliance@electrotech.de&quot;&#xD;&#xA;      }&#xD;&#xA;    },&#xD;&#xA;    &quot;authorizedRepresentative&quot;: {&#xD;&#xA;      &quot;legalName&quot;: &quot;Compliance Partners SRL&quot;,&#xD;&#xA;      &quot;address&quot;: {&#xD;&#xA;        &quot;street&quot;: &quot;Via del Commercio 10&quot;,&#xD;&#xA;        &quot;city&quot;: &quot;Milan&quot;,&#xD;&#xA;        &quot;postalCode&quot;: &quot;20121&quot;,&#xD;&#xA;        &quot;country&quot;: &quot;Italy&quot;&#xD;&#xA;      },&#xD;&#xA;      &quot;contact&quot;: {&#xD;&#xA;        &quot;person&quot;: &quot;Mr. Marco Rossi&quot;,&#xD;&#xA;        &quot;phone&quot;: &quot;+39 02 9876543&quot;,&#xD;&#xA;        &quot;email&quot;: &quot;marco.rossi@compliancepartners.it&quot;&#xD;&#xA;      }&#xD;&#xA;    },&#xD;&#xA;    &quot;product&quot;: {&#xD;&#xA;      &quot;productName&quot;: &quot;SmartHome Hub Pro&quot;,&#xD;&#xA;      &quot;modelNumber&quot;: &quot;SHP-2000&quot;,&#xD;&#xA;      &quot;serialNumberRange&quot;: &quot;SHP2000-10001 to SHP2000-20000&quot;,&#xD;&#xA;      &quot;productCategory&quot;: &quot;Radio equipment and low-voltage electronic device&quot;,&#xD;&#xA;      &quot;description&quot;: &quot;Central home automation gateway with Zigbee, Wi-Fi, and BLE, supporting up to 100 devices, with built-in power supply (100-240V AC, 50/60Hz).&quot;,&#xD;&#xA;      &quot;intendedUse&quot;: &quot;Indoor residential and light commercial building automation.&quot;,&#xD;&#xA;      &quot;accessoriesIncluded&quot;: [&#xD;&#xA;        {&#xD;&#xA;          &quot;name&quot;: &quot;Power Adapter&quot;,&#xD;&#xA;          &quot;model&quot;: &quot;PA-12V2A&quot;,&#xD;&#xA;          &quot;certification&quot;: &quot;IEC 62368-1&quot;&#xD;&#xA;        },&#xD;&#xA;        {&#xD;&#xA;          &quot;name&quot;: &quot;Ethernet Cable&quot;,&#xD;&#xA;          &quot;model&quot;: &quot;CAT6-1.5m&quot;,&#xD;&#xA;          &quot;certification&quot;: &quot;ISO/IEC 11801&quot;&#xD;&#xA;        }&#xD;&#xA;      ]&#xD;&#xA;    },&#xD;&#xA;    &quot;applicableDirectives&quot;: [&#xD;&#xA;      {&#xD;&#xA;        &quot;directive&quot;: &quot;Radio Equipment Directive&quot;,&#xD;&#xA;        &quot;reference&quot;: &quot;2014/53/EU&quot;,&#xD;&#xA;        &quot;harmonizedStandards&quot;: [&#xD;&#xA;          &quot;EN 301 489-1 V2.2.3 (EMC for radio)&quot;,&#xD;&#xA;          &quot;EN 301 489-17 V3.2.4 (EMC for broadband)&quot;,&#xD;&#xA;          &quot;EN 300 328 V2.2.2 (2.4 GHz band)&quot;,&#xD;&#xA;          &quot;EN 303 645 V2.1.1 (Cybersecurity)&quot;&#xD;&#xA;        ]&#xD;&#xA;      },&#xD;&#xA;      {&#xD;&#xA;        &quot;directive&quot;: &quot;Low Voltage Directive&quot;,&#xD;&#xA;        &quot;reference&quot;: &quot;2014/35/EU&quot;,&#xD;&#xA;        &quot;harmonizedStandards&quot;: [&#xD;&#xA;          &quot;EN 62368-1:2020 (Safety)&quot;,&#xD;&#xA;          &quot;EN 60335-1:2012/A15:2021 (Household safety)&quot;&#xD;&#xA;        ]&#xD;&#xA;      },&#xD;&#xA;      {&#xD;&#xA;        &quot;directive&quot;: &quot;EMC Directive&quot;,&#xD;&#xA;        &quot;reference&quot;: &quot;2014/30/EU&quot;,&#xD;&#xA;        &quot;harmonizedStandards&quot;: [&#xD;&#xA;          &quot;EN 55032:2015/A11:2020 (Emissions)&quot;,&#xD;&#xA;          &quot;EN 55035:2017/A11:2020 (Immunity)&quot;,&#xD;&#xA;          &quot;EN 61000-3-2:2019 (Harmonics)&quot;,&#xD;&#xA;          &quot;EN 61000-3-3:2013/A2:2021 (Flicker)&quot;&#xD;&#xA;        ]&#xD;&#xA;      },&#xD;&#xA;      {&#xD;&#xA;        &quot;directive&quot;: &quot;RoHS Directive&quot;,&#xD;&#xA;        &quot;reference&quot;: &quot;2011/65/EU (including 2015/863/EU)&quot;,&#xD;&#xA;        &quot;harmonizedStandards&quot;: [&#xD;&#xA;          &quot;EN IEC 63000:2018 (Technical documentation for RoHS)&quot;&#xD;&#xA;        ]&#xD;&#xA;      },&#xD;&#xA;      {&#xD;&#xA;        &quot;directive&quot;: &quot;WEEE Directive&quot;,&#xD;&#xA;        &quot;reference&quot;: &quot;2012/19/EU&quot;,&#xD;&#xA;        &quot;harmonizedStandards&quot;: [&#xD;&#xA;          &quot;EN 50419:2022 (Marking of electrical equipment)&quot;&#xD;&#xA;        ]&#xD;&#xA;      },&#xD;&#xA;      {&#xD;&#xA;        &quot;directive&quot;: &quot;Eco-design Directive&quot;,&#xD;&#xA;        &quot;reference&quot;: &quot;2009/125/EC&quot;,&#xD;&#xA;        &quot;harmonizedStandards&quot;: [&#xD;&#xA;          &quot;Regulation (EU) 2023/826 (Standby and off-mode power)&quot;&#xD;&#xA;        ]&#xD;&#xA;      }&#xD;&#xA;    ],&#xD;&#xA;    &quot;notifiedBody&quot;: {&#xD;&#xA;      &quot;name&quot;: &quot;TÜV Rheinland LGA Products GmbH&quot;,&#xD;&#xA;      &quot;notifiedBodyNumber&quot;: &quot;0197&quot;,&#xD;&#xA;      &quot;address&quot;: {&#xD;&#xA;        &quot;street&quot;: &quot;Tillystrasse 2&quot;,&#xD;&#xA;        &quot;city&quot;: &quot;Nuremberg&quot;,&#xD;&#xA;        &quot;postalCode&quot;: &quot;90431&quot;,&#xD;&#xA;        &quot;country&quot;: &quot;Germany&quot;&#xD;&#xA;      },&#xD;&#xA;      &quot;certificateNumber&quot;: &quot;TRL-2026-0452&quot;,&#xD;&#xA;      &quot;certificateDate&quot;: &quot;2026-05-15&quot;&#xD;&#xA;    },&#xD;&#xA;    &quot;testReports&quot;: [&#xD;&#xA;      {&#xD;&#xA;        &quot;reportId&quot;: &quot;EMC-2026-112A&quot;,&#xD;&#xA;        &quot;testLab&quot;: &quot;Eurofins E&amp;E Germany&quot;,&#xD;&#xA;        &quot;date&quot;: &quot;2026-04-10&quot;,&#xD;&#xA;        &quot;standard&quot;: &quot;EN 55032:2015&quot;,&#xD;&#xA;        &quot;result&quot;: &quot;PASS&quot;&#xD;&#xA;      },&#xD;&#xA;      {&#xD;&#xA;        &quot;reportId&quot;: &quot;SAFE-2026-89B&quot;,&#xD;&#xA;        &quot;testLab&quot;: &quot;UL International&quot;,&#xD;&#xA;        &quot;date&quot;: &quot;2026-03-22&quot;,&#xD;&#xA;        &quot;standard&quot;: &quot;EN 62368-1:2020&quot;,&#xD;&#xA;        &quot;result&quot;: &quot;PASS&quot;&#xD;&#xA;      },&#xD;&#xA;      {&#xD;&#xA;        &quot;reportId&quot;: &quot;RADIO-2026-34C&quot;,&#xD;&#xA;        &quot;testLab&quot;: &quot;SGS Fimko Oy&quot;,&#xD;&#xA;        &quot;date&quot;: &quot;2026-05-02&quot;,&#xD;&#xA;        &quot;standard&quot;: &quot;EN 300 328 V2.2.2&quot;,&#xD;&#xA;        &quot;result&quot;: &quot;PASS&quot;&#xD;&#xA;      }&#xD;&#xA;    ],&#xD;&#xA;    &quot;technicalDocumentation&quot;: {&#xD;&#xA;      &quot;location&quot;: &quot;ElectroTech GmbH, Document Archive, Room 3.2&quot;,&#xD;&#xA;      &quot;responsiblePerson&quot;: &quot;Dr. Anna Schmidt&quot;,&#xD;&#xA;      &quot;availabilityPeriod&quot;: &quot;10 years from last production date&quot;,&#xD;&#xA;      &quot;files&quot;: [&#xD;&#xA;        &quot;SHP-2000_Schematics_v3.pdf&quot;,&#xD;&#xA;        &quot;SHP-2000_BOM_v5.xlsx&quot;,&#xD;&#xA;        &quot;SHP-2000_Firmware_CRC32.hex&quot;,&#xD;&#xA;        &quot;SHP-2000_RiskAssessment_v2.docx&quot;,&#xD;&#xA;        &quot;SHP-2000_UserManual_EN_DE_FR_IT_ES.pdf&quot;,&#xD;&#xA;        &quot;SHP-2000_LabelArtwork.ai&quot;&#xD;&#xA;      ]&#xD;&#xA;    },&#xD;&#xA;    &quot;conformityAssessmentProcedure&quot;: &quot;Module B (EU-type examination) + Module C (conformity to type) per Radio Equipment Directive, combined with internal production control per Low Voltage and EMC.&quot;,&#xD;&#xA;    &quot;supplementaryInformation&quot;: {&#xD;&#xA;      &quot;restrictedSubstances&quot;: [&#xD;&#xA;        {&#xD;&#xA;          &quot;substance&quot;: &quot;Lead&quot;,&#xD;&#xA;          &quot;maxConcentration&quot;: &quot;0.1%&quot;,&#xD;&#xA;          &quot;compliance&quot;: &quot;Yes (exemptions apply for solder joints under RoHS 7(c)-I)&quot;&#xD;&#xA;        },&#xD;&#xA;        {&#xD;&#xA;          &quot;substance&quot;: &quot;Cadmium&quot;,&#xD;&#xA;          &quot;maxConcentration&quot;: &quot;0.01%&quot;,&#xD;&#xA;          &quot;compliance&quot;: &quot;Yes&quot;&#xD;&#xA;        }&#xD;&#xA;      ],&#xD;&#xA;      &quot;frequencyBands&quot;: [&#xD;&#xA;        {&#xD;&#xA;          &quot;band&quot;: &quot;2.400 – 2.4835 GHz&quot;,&#xD;&#xA;          &quot;maxTransmitPower&quot;: &quot;20 dBm (EIRP)&quot;,&#xD;&#xA;          &quot;technology&quot;: &quot;Zigbee &amp; BLE&quot;&#xD;&#xA;        },&#xD;&#xA;        {&#xD;&#xA;          &quot;band&quot;: &quot;2.412 – 2.472 GHz&quot;,&#xD;&#xA;          &quot;maxTransmitPower&quot;: &quot;18 dBm (EIRP)&quot;,&#xD;&#xA;          &quot;technology&quot;: &quot;Wi-Fi 802.11 b/g/n&quot;&#xD;&#xA;        }&#xD;&#xA;      ],&#xD;&#xA;      &quot;powerConsumption&quot;: {&#xD;&#xA;        &quot;standby&quot;: &quot;0.5 W&quot;,&#xD;&#xA;        &quot;operational&quot;: &quot;8.0 W&quot;,&#xD;&#xA;        &quot;peak&quot;: &quot;15.0 W&quot;&#xD;&#xA;      },&#xD;&#xA;      &quot;ipRating&quot;: &quot;IP20 (indoor use only)&quot;,&#xD;&#xA;      &quot;operatingTemperature&quot;: &quot;0°C to +40°C&quot;&#xD;&#xA;    },&#xD;&#xA;    &quot;declarationStatement&quot;: &quot;We hereby declare that the product described above is in conformity with all applicable Union harmonisation legislation and that all necessary tests and assessments have been carried out. The technical documentation is maintained and will be made available to competent authorities upon request.&quot;,&#xD;&#xA;    &quot;signatory&quot;: {&#xD;&#xA;      &quot;name&quot;: &quot;Dr. Anna Schmidt&quot;,&#xD;&#xA;      &quot;title&quot;: &quot;Managing Director - Quality &amp; Compliance&quot;,&#xD;&#xA;      &quot;place&quot;: &quot;Berlin&quot;,&#xD;&#xA;      &quot;date&quot;: &quot;2026-06-24&quot;,&#xD;&#xA;      &quot;signature&quot;: &quot;Digital signature on file (SHA-256: 7A3F8B2C...)&quot;&#xD;&#xA;    }&#xD;&#xA;  },&#xD;&#xA;  &quot;metadata&quot;: {&#xD;&#xA;    &quot;generatedBy&quot;: &quot;Demo-Data AI v2.0&quot;,&#xD;&#xA;    &quot;timestamp&quot;: &quot;2026-06-24T10:30:00Z&quot;,&#xD;&#xA;    &quot;schemaVersion&quot;: &quot;1.0&quot;,&#xD;&#xA;    &quot;validity&quot;: &quot;This declaration remains valid as long as no changes to the product or applicable regulations occur.&quot;&#xD;&#xA;  }&#xD;&#xA;}"
      TypeName="String"
      UserData="" />
